global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Node Exporter (app server)
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['{{ app_server_ip }}:{{ node_exporter_port }}']
        labels:
          instance: 'app-server'

  # cAdvisor (app server containers)
  - job_name: 'cadvisor'
    static_configs:
      - targets: ['{{ app_server_ip }}:{{ cadvisor_port }}']
        labels:
          instance: 'app-server'

  # Application health (Blackbox-style via app server)
  - job_name: 'app-health'
    metrics_path: /login
    static_configs:
      - targets: ['{{ app_server_ip }}:80']
