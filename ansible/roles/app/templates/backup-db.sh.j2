#!/bin/bash
# PostgreSQL backup script
BACKUP_DIR="{{ deploy_dir }}/backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="$BACKUP_DIR/habitdb_$TIMESTAMP.sql.gz"

mkdir -p "$BACKUP_DIR"

# Dump database from Docker container
docker exec {{ project_name }}_db pg_dump -U {{ db_user }} {{ db_name }} | gzip > "$BACKUP_FILE"

# Keep only last 7 backups
ls -t "$BACKUP_DIR"/habitdb_*.sql.gz | tail -n +8 | xargs -r rm

echo "Backup created: $BACKUP_FILE ($(du -h "$BACKUP_FILE" | cut -f1))"
