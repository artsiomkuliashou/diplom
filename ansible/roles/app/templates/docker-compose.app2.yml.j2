services:
  database-replica:
    image: postgres:15.13-alpine
    container_name: {{ project_name }}_db_replica
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${DB_NAME}
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      PGDATA: /var/lib/postgresql/data/pgdata
      PGPASSWORD: ${PG_REPL_PASSWORD}
    command: >
      bash -c "
      if [ ! -f /var/lib/postgresql/data/pgdata/standby.signal ]; then
        rm -rf /var/lib/postgresql/data/pgdata;
        until pg_isready -h {{ app_server_ip }} -p 5432 -U {{ pg_replication_user }}; do
          echo 'Waiting for primary...'; sleep 2;
        done;
        PGPASSWORD=${PG_REPL_PASSWORD} pg_basebackup -h {{ app_server_ip }} -p 5432 -U {{ pg_replication_user }} -D /var/lib/postgresql/data/pgdata -Fp -Xs -R;
      fi;
      exec postgres
      "
    volumes:
      - postgres_replica_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 10
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - app_network

  app:
    image: {{ app_image }}
    container_name: {{ project_name }}_app2
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      DATABASE_URL: postgres://${DB_USER}:${DB_PASSWORD}@database-replica:5432/${DB_NAME}?sslmode=disable
    depends_on:
      database-replica:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget --server-response --spider http://localhost:8080/login 2>&1 | grep -q 'HTTP'"]
      interval: 30s
      timeout: 10s
      retries: 3
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - app_network

  node-exporter:
    image: prom/node-exporter:v1.9.0
    container_name: {{ project_name }}_node_exporter2
    restart: unless-stopped
    command:
      - '--path.rootfs=/host'
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/host:ro,rslave
    ports:
      - "{{ node_exporter_port }}:9100"
    networks:
      - app_network

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.51.0
    container_name: {{ project_name }}_cadvisor2
    restart: unless-stopped
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "{{ cadvisor_port }}:8080"
    privileged: true
    devices:
      - /dev/kmsg:/dev/kmsg
    networks:
      - app_network

  postgres-exporter:
    image: prometheuscommunity/postgres-exporter:v0.16.0
    container_name: {{ project_name }}_postgres_exporter2
    restart: unless-stopped
    environment:
      DATA_SOURCE_NAME: "postgresql://${DB_USER}:${DB_PASSWORD}@database-replica:5432/${DB_NAME}?sslmode=disable"
    ports:
      - "{{ postgres_exporter_port }}:9187"
    depends_on:
      database-replica:
        condition: service_healthy
    networks:
      - app_network

  filebeat:
    image: docker.elastic.co/beats/filebeat:8.17.0
    container_name: {{ project_name }}_filebeat2
    restart: unless-stopped
    user: root
    command: ["filebeat", "-e", "--strict.perms=false"]
    volumes:
      - ./filebeat.yml:/usr/share/filebeat/filebeat.yml:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      - LOGSTASH_HOST={{ monitoring_server_ip }}
      - LOGSTASH_PORT={{ logstash_port }}
    networks:
      - app_network

  nginx-standby:
    image: nginx:1.27-alpine
    container_name: {{ project_name }}_nginx_standby
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      app:
        condition: service_healthy
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - app_network
    profiles:
      - standby

volumes:
  postgres_replica_data:
    driver: local

networks:
  app_network:
    driver: bridge
