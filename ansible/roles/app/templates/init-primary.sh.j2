#!/bin/bash
set -e

# Create replication user
psql -v ON_ERROR_STOP=1 --username "$POSTGRES_USER" --dbname "$POSTGRES_DB" <<-EOSQL
    CREATE USER {{ pg_replication_user }} WITH REPLICATION ENCRYPTED PASSWORD '{{ pg_replication_password }}';
EOSQL

# Configure postgresql.conf for replication
cat >> /var/lib/postgresql/data/postgresql.conf <<EOF
wal_level = replica
max_wal_senders = 3
wal_keep_size = 64
EOF

# Allow replica to connect
echo "host replication {{ pg_replication_user }} {{ vpc_cidr }} md5" >> /var/lib/postgresql/data/pg_hba.conf
